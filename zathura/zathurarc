# STR Zathura — skuwii

set default-bg "#0e0f11"
set default-fg "#c8ccd4"

set statusbar-bg "#1c1e21"
set statusbar-fg "#8a8f98"

set inputbar-bg "#1c1e21"
set inputbar-fg "#c8ccd4"

set notification-bg "#1c1e21"
set notification-fg "#c8ccd4"
set notification-error-bg "#c0392b"
set notification-error-fg "#c8ccd4"
set notification-warning-bg "#1c1e21"
set notification-warning-fg "#2980d4"

set highlight-color "#2980d4"
set highlight-active-color "#2980d4"

set completion-bg "#1c1e21"
set completion-fg "#8a8f98"
set completion-highlight-bg "#2980d4"
set completion-highlight-fg "#0e0f11"

set recolor true
set recolor-lightcolor "#0e0f11"
set recolor-darkcolor "#c8ccd4"

set font "JetBrains Mono 11"
set guioptions none
set statusbar-h-padding 10
set statusbar-v-padding 5

# Keybinds
map <C-=> zoom in
map <C--> zoom out
map R rotate rotate-cw
map r reload
